# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=db_websangkima

# Application Environment
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=1h

# Email Configuration (SMTP)
# Development: OTP akan ditampilkan di console
# Production: Gunakan SMTP untuk mengirim email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@desasangkima.com

# Optional: API Base URL (for production)
# NEXT_PUBLIC_API_URL=http://localhost:3000

NEXT_PUBLIC_APP_URL=your-frontend-url-here